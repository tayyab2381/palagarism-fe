# =============================================================================
# PlagiarCheck — Environment Variables
# Copy this file to .env.local and replace placeholder values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Supabase Postgres connection string
# Supabase: Project Settings → Database → Connection string (URI)
# Replace with any Postgres URL when self-hosting.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Auth — JWT signing secret
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-here

# -----------------------------------------------------------------------------
# Plagiarism provider strategy
#   auto          — Google first, Copyleaks fallback (recommended for MVP)
#   google        — Google Custom Search only
#   google-search — alias for google
#   copyleaks     — Copyleaks only (use when going live)
# -----------------------------------------------------------------------------
PLAGIARISM_PROVIDER=auto

# -----------------------------------------------------------------------------
# Google Custom Search — priority 1 (free tier: 100 queries/day)
# API key: https://console.cloud.google.com/apis/credentials
# Search engine: https://programmablesearchengine.google.com/
# -----------------------------------------------------------------------------
GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-api-key
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your-custom-search-engine-id

# Legacy aliases (optional — use GOOGLE_CUSTOM_SEARCH_* above instead)
# GOOGLE_SEARCH_API_KEY=your-google-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-custom-search-engine-id

# -----------------------------------------------------------------------------
# Copyleaks — priority 2 fallback / production provider (optional for MVP)
# Sign up: https://api.copyleaks.com
# -----------------------------------------------------------------------------
PLAGIARISM_API_KEY=your-copyleaks-api-key
PLAGIARISM_API_EMAIL=you@example.com

# Sandbox mode — true for free dev scans, false for production (uses credits)
COPYLEAKS_SANDBOX=true

# -----------------------------------------------------------------------------
# App
# Must be publicly reachable when using Copyleaks webhooks (use ngrok locally).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
