# Supabase Postgres connection string — used by pg Pool in src/lib/db.ts
DATABASE_URL=

# Supabase project URL — used for auth API calls
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — client-side auth only
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase JWT secret — used by jose in src/lib/auth.ts for token verification
SUPABASE_JWT_SECRET=

# Copyleaks free-tier API key — used by plagiarism provider
COPYLEAKS_API_KEY=
