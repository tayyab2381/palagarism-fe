# Postgres connection string — used by pg Pool in src/lib/db.ts
DATABASE_URL=postgresql://user:password@localhost:5432/plagiarcheck

# Secret for signing and verifying JWTs — used by src/lib/auth.ts
JWT_SECRET=replace-with-a-long-random-secret

# Active plagiarism provider — "copyleaks" or "google"
PLAGIARISM_PROVIDER=google

# Copyleaks API key — required when PLAGIARISM_PROVIDER=copyleaks
PLAGIARISM_API_KEY=replace-with-your-copyleaks-api-key

# Copyleaks account email — required when PLAGIARISM_PROVIDER=copyleaks
PLAGIARISM_API_EMAIL=you@example.com

# Google Custom Search — required when PLAGIARISM_PROVIDER=google
GOOGLE_CUSTOM_SEARCH_API_KEY=replace-with-your-google-api-key
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=replace-with-your-search-engine-id

# Public app URL — used for redirects, webhooks, and client-side links
NEXT_PUBLIC_APP_URL=http://localhost:3000
