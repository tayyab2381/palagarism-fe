# =============================================================================
# PlagiarCheck — Environment Variables
# Copy this file to .env.local and replace placeholder values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Supabase Postgres connection string
# Local dev:  Project Settings → Database → URI (direct, port 5432)
# Vercel:     use Transaction pooler (port 6543) — direct db.*:5432 often fails
#             Project Settings → Database → Connection pooling → Transaction mode
# Password special chars must be URL-encoded (? → %3F, @ → %40, # → %23)
# -----------------------------------------------------------------------------
# Local (direct)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Pooler (recommended for local + Vercel) — copy exact host from Supabase dashboard
# Host may be aws-0 or aws-1 depending on project (e.g. aws-1-ap-northeast-1)
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Auth — JWT signing secret
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-here

# -----------------------------------------------------------------------------
# Copyleaks — plagiarism detection provider
# Sign up: https://api.copyleaks.com
# -----------------------------------------------------------------------------
PLAGIARISM_API_KEY=your-copyleaks-api-key
PLAGIARISM_API_EMAIL=you@example.com

# Sandbox mode — true for free dev scans, false for production (uses credits)
COPYLEAKS_SANDBOX=true

# -----------------------------------------------------------------------------
# App environment
# development — bypasses auth middleware, API auth, rate limits, and provider
#             credential validation (NEVER use in production)
# production  — full auth and validation (default when unset)
# -----------------------------------------------------------------------------
APP_ENV=development

# -----------------------------------------------------------------------------
# App
# Must be publicly reachable for Copyleaks webhooks (use ngrok locally).
# Production: https://your-domain.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
